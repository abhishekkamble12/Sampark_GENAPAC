# ──────────────────────────────────────────────────────────────────────────────
# Sampark AI Platform — Environment Configuration
# Google ADK-powered, full Google Cloud ecosystem
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Application Mode ──────────────────────────────────────────────────────────
# "local" = demo mode (in-memory DB, demo auth, mock services)
# "production" = full Google Cloud (real Firestore, Firebase Auth, Vertex AI)
APP_MODE=local

# ── Google Cloud Project ──────────────────────────────────────────────────────
GCP_PROJECT_ID=sampark-demo
GCP_LOCATION=us-central1
BIGQUERY_DATASET=sampark_analytics

# ── Google ADK (Gemini API) ──────────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key

# Set to True to use Vertex AI (Google Cloud) instead of Gemini API
GOOGLE_GENAI_USE_ENTERPRISE=False

# ── Vertex AI RAG Engine ─────────────────────────────────────────────────────
# Create a RAG corpus first:
#   python scripts/setup_rag_corpus.py
RAG_CORPUS_ID=
RAG_CORPUS_NAME=

# ── External APIs ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-maps-api-key
OPENWEATHER_API_KEY=your-weather-api-key

# ── Firebase Admin SDK (production only) ─────────────────────────────────────
# Path to your Firebase service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=

# ── Demo Credentials (local mode only) ───────────────────────────────────────
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123
DEMO_LEADER_USERNAME=leader
DEMO_LEADER_PASSWORD=leader123

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
