# =============================================================================
# Sampark AI Platform — Environment Variables (FREE Stack)
# =============================================================================
#
# Copy this file to .env (never commit .env to version control) and fill in
# real values as needed.
#
# No Google Cloud services or billing required. Everything runs on free tiers.
# =============================================================================


# ---------------------------------------------------------------------------
# Application Mode
# ---------------------------------------------------------------------------

# Controls whether the platform uses mock data or real API calls.
#   local    — Mock mode: no API keys needed (default)
#   demo     — Uses real Gemini/Weather/Maps APIs if keys are provided
APP_MODE=local


# ---------------------------------------------------------------------------
# FREE AI: Google AI Studio (replaces Vertex AI)
# Get your free API key: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------

# Required only if APP_MODE != local
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Gemini embedding model for RAG (default: models/text-embedding-004)
GEMINI_EMBEDDING_MODEL=models/text-embedding-004


# ---------------------------------------------------------------------------
# JWT Authentication (built-in, no Firebase needed)
# ---------------------------------------------------------------------------

# JWT signing secret for token generation and verification.
# Change this in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sampark_dev_secret_key


# ---------------------------------------------------------------------------
# Optional Third-Party APIs (free tiers)
# ---------------------------------------------------------------------------

# Google Maps API key for geocoding (free tier available)
# Get: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# OpenWeatherMap API key for weather data (free: 1,000 calls/day)
# Sign up: https://openweathermap.org/api
OPENWEATHER_API_KEY=


# ---------------------------------------------------------------------------
# Local Database Paths (replaces Firestore + BigQuery + Cloud Storage)
# All data stored locally, zero-config, zero cost.
# ---------------------------------------------------------------------------

# SQLite database path (operational data — issues, tasks, users)
SQLITE_DB_PATH=data/sampark.db

# DuckDB analytics path (dashboard queries, health scores, trends)
DUCKDB_PATH=data/sampark_analytics.duckdb

# FAISS vector index path (RAG policy embeddings)
FAISS_INDEX_PATH=data/policy_index.faiss

# FAISS metadata file path
VECTOR_METADATA_PATH=data/policy_metadata.json


# ---------------------------------------------------------------------------
# Event System
# ---------------------------------------------------------------------------

# Use in-memory async queue instead of Pub/Sub (default: true)
USE_ASYNC_QUEUE=true


# ---------------------------------------------------------------------------
# Demo Credentials (for local development)
# ---------------------------------------------------------------------------

DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=password

DEMO_LEADER_USERNAME=leader_w1
DEMO_LEADER_PASSWORD=password


# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Allowed origins for the frontend (comma-separated)
# Use "*" for development, restrict in production
CORS_ALLOWED_ORIGINS=*
