# =============================================================================
# Sampark AI Platform — Environment Variables
# =============================================================================
#
# This file documents ALL required environment variables for local development
# and CI/CD pipelines. Copy this file to .env (never commit .env to version
# control) and fill in real values.
#
# In production, these values are sourced from Google Secret Manager.
# The corresponding Secret Manager secret IDs are noted next to each variable.
# To populate a secret:
#   gcloud secrets versions add <SECRET_ID> \
#     --data-file=<path-to-value-file> --project=<YOUR_PROJECT_ID>
# =============================================================================


# -----------------------------------------------------------------------------
# Google Cloud — Project Configuration
# (non-secret; safe to commit as plain env vars in CI)
# -----------------------------------------------------------------------------

# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Deployment region (default: asia-south1)
REGION=asia-south1


# -----------------------------------------------------------------------------
# api-gateway service secrets
# Secret Manager ID: sampark-jwt-secret-key
# -----------------------------------------------------------------------------

# JWT signing key used by FastAPI to sign and verify access tokens.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET


# Secret Manager ID: sampark-firebase-credentials
# Firebase Admin SDK service account JSON (the full JSON blob, base64-encoded
# or as raw JSON depending on how your app reads it).
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS=REPLACE_WITH_FIREBASE_ADMIN_SDK_JSON_OR_BASE64


# Secret Manager ID: sampark-redis-url
# Memorystore Redis connection URL used for session caching and rate limiting.
# Format: redis://<HOST>:<PORT>  (no password for VPC-internal Memorystore)
# Local dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# langgraph-engine service secrets
# Secret Manager ID: sampark-vertex-ai-api-key
# -----------------------------------------------------------------------------

# API key for Vertex AI (Gemini models, embeddings, etc.).
# Create at: https://console.cloud.google.com/apis/credentials
VERTEX_AI_API_KEY=REPLACE_WITH_VERTEX_AI_API_KEY


# Secret Manager ID: sampark-google-maps-api-key
# Google Maps Platform API key for geocoding and routing tools used by the
# LangGraph location-intelligence agent.
# Create at: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_API_KEY


# Secret Manager ID: sampark-weather-api-key
# OpenWeatherMap (or compatible) API key for the weather-data tool.
# Sign up at: https://openweathermap.org/api
WEATHER_API_KEY=REPLACE_WITH_OPENWEATHERMAP_OR_SIMILAR_API_KEY


# Secret Manager ID: sampark-firestore-database-id
# Firestore database ID. Use "(default)" for the default database, or the
# named database ID if you created a non-default Firestore instance.
FIRESTORE_DATABASE_ID=(default)


# -----------------------------------------------------------------------------
# notification-worker service secrets
# Secret Manager ID: sampark-twilio-account-sid
# -----------------------------------------------------------------------------

# Twilio Account SID — found on the Twilio Console dashboard.
# Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Secret Manager ID: sampark-twilio-auth-token
# Twilio Auth Token — found on the Twilio Console dashboard.
# Treat this like a password; never log or expose it.
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN


# Secret Manager ID: sampark-sendgrid-api-key
# SendGrid API key for transactional email delivery.
# Create at: https://app.sendgrid.com/settings/api_keys
# Required permission: Mail Send (Full Access)
SENDGRID_API_KEY=SG.REPLACE_WITH_SENDGRID_API_KEY


# Secret Manager ID: sampark-fcm-server-key
# Firebase Cloud Messaging server key for push notifications.
# Obtain from: Firebase Console → Project Settings → Cloud Messaging → Server key
# Note: For new projects, use a service-account-based approach (FCM v1 API)
# rather than the legacy server key.
FCM_SERVER_KEY=REPLACE_WITH_FCM_SERVER_KEY


# -----------------------------------------------------------------------------
# Local development overrides (not used in Cloud Run)
# -----------------------------------------------------------------------------

# Set to "development" locally, "production" in Cloud Run
ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# =============================================================================
# Local Development Mode Defaults (Just copy-paste this to your .env)
# =============================================================================
APP_MODE=local
JWT_SECRET=mock_secret_key
CORS_ALLOWED_ORIGINS=http://localhost:5173
GCP_PROJECT_ID=sampark-demo
BIGQUERY_DATASET=sampark_analytics
FIRESTORE_DATABASE=(default)
PUBSUB_TOPIC_TASK_CREATED=task-created

# Not required in local mode but placeholder for completion
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=
